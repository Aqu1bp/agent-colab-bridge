# Copy to .env for local shell use. Do not commit real values.

COLAB_MCP_BRIDGE_BASE_URL=https://<worker-name>.<cloudflare-subdomain>.workers.dev
COLAB_MCP_BRIDGE_ADMIN_SECRET=<admin-secret>

# Optional local MCP/session values.
COLAB_MCP_BRIDGE_CONFIG=~/.config/agent-colab-bridge/config.json
COLAB_MCP_BRIDGE_SESSION_ID=<session-id>
COLAB_MCP_BRIDGE_CONTROLLER_TOKEN=<controller-token>
COLAB_MCP_BRIDGE_RUNNER_TOKEN=<runner-token>

# Set to 1 only when you intentionally allow remote shell/Python/file-write/job tools.
COLAB_MCP_BRIDGE_ENABLE_DANGEROUS_TOOLS=0
